// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  PRODUCER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Product{
  id String @id @default(uuid())
  name String  @unique
  description String?
  price Int //Kuruş cinsinden
  stock Int @default(0) 
  isActive Boolean @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ilişkiler

  category Category? @relation(fields: [categoryId], references:[id], onDelete:SetNull)
  categoryId String?

  producer Producer? @relation(fields:[producerId], references:[id], onDelete:SetNull)
  producerId String?

  tags Tag[]

  @@map("products")
  // @@unique()
  // @@index([name])
  // @@id([id,productId])
}

model Category {
  id String @id @default(uuid())
  name String @unique
  slug String @unique
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //ilişkiler
  products Product[]

  @@map("categories")
}

model Producer {
  id        String    @id @default(uuid())
  name      String    @unique
  city      String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@map("producers")
}

model Tag{
  id  String @id @default(uuid())
  name String @unique
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products Product[]

  @@map("tags")
}

model User {
  id String @id @default(uuid())
  email String @unique
  name String
  password String 
  role Role @default(CUSTOMER)
  isActive Boolean @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt


  @@map("users")
}